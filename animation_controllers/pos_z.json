        "controller.animation.pos_z.sign": {
            "states": {
                "positive": {
                    "transitions": [
                        {
                            "negative": "q.position(2) \u003c 0"
                        }
                    ],
                    "on_entry": [
                        "/scoreboard objectives add z_sign dummy",
                        "/scoreboard players set @s z_sign 1"
                    ]
                },
                "negative": {
                    "transitions": [
                        {
                            "positive": "q.position(2) \u003e= 0"
                        }
                    ],
                    "on_entry": [
                        "/scoreboard objectives add z_sign dummy",
                        "/scoreboard players set @s z_sign -1"
                    ]
                }
            },
            "initial_state": "positive"
        },
