        "controller.animation.xz_speed.digit_0": {
            "states": {
                "default_state": {
                    "transitions": [{ "running_state": "(q.time_stamp - v.time_stamp) > 1" }],
                    "on_entry": [
                        "v.pos_x = q.position(0); v.pos_z = q.position(2); v.time_stamp = q.time_stamp; v.xz_digit_0 = 0;"                    ]
                },
                "running_state": {
                    "on_exit": ["v.time_stamp = q.time_stamp;"],
                    "transitions": [
                        { "d0.0": "v.xz_digit_0 == 0" },
